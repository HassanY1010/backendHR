# =============================================================================
# AI HR Platform — Backend Environment Variables
# =============================================================================
# انسخ هذا الملف إلى .env وعدّل القيم حسب بيئتك
# cp .env.example .env
# =============================================================================

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development                         # development | production | test
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
LANDING_PAGE_URL=http://localhost:5173

# ─── Database (MySQL) ───────────────────────────────────────────────────────
# تنسيق: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/ai_hr_platform"

# ─── JWT (Authentication) ────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=90d

# ─── Dashboard URLs (used for auth redirects) ────────────────────────────────
SUPER_ADMIN_DASHBOARD_URL=http://localhost:3002
MANAGER_DASHBOARD_URL=http://localhost:3001
EMPLOYEE_DASHBOARD_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Supabase Storage (for file uploads) ─────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # fallback if SERVICE_ROLE_KEY not set

# ─── Redis (Background Jobs + Caching) ──────────────────────────────────────
# اختياري — في حال عدم ضبطه، يستخدم InMemory Queue كبديل
REDIS_URL=redis://localhost:6379
REDIS_PUBLIC_URL=                            # للإنتاج (مثلاً من Railway)
# بدائل منفصلة:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ─── Resend (Email) ─────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# ─── ClamAV (Antivirus for uploaded files) ──────────────────────────────────
# اختياري — إذا لم يتوفر، يتم تخطي فحص الفيروسات مع تسجيل تحذير
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info                              # debug | info | warn | error

# ─── External Flags (used by code internally) ────────────────────────────────
# RAILWAY_ENVIRONMENT=true                   # يُضبط تلقائياً عند النشر على Railway
